rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // True if `uid` is a participant (employer, hired operator, or applicant)
    // of the given job. Used to bound who can send whom a notification —
    // without this, any authenticated user could spam/phish any other user
    // (see AGENTS.md security notes / audit S2).
    function isJobParticipant(jobId, uid) {
      let job = get(/databases/$(database)/documents/jobs/$(jobId)).data;
      return job.employerId == uid ||
        ('hiredOperatorId' in job && job.hiredOperatorId == uid) ||
        (uid in job.applicants);
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Single-document read only (get), authenticated. `list` is explicitly
      // denied so no client can enumerate/scan the whole collection — that
      // would hand out every user's phone/email/address/password-hash in one
      // shot. Any UI that needs several profiles must fetch them one-by-one
      // by known id (see getUsersByIds in src/lib/db/users.ts); the aggregate
      // "registered users" count is served by the getUserCount Cloud Function.
      allow get: if request.auth != null;
      allow list: if false;

      // Only authenticated users may create their OWN document (UID must match)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Owner may update anything on their own document. rating/ratingCount are
      // NOT client-writable by anyone (previously any auth'd user could bump
      // any other user's rating with no review behind it — audit S2); they are
      // recalculated server-side by the onReviewWrite Cloud Function trigger,
      // which uses the Admin SDK and bypasses these rules entirely.
      allow update: if request.auth != null && request.auth.uid == userId;

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Jobs ───────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      // Public read: job board visible to guests
      allow read: if true;

      // Job creation happens ONLY through the createJob Cloud Function (Admin
      // SDK, bypasses these rules) — it enforces a per-employer rate limit
      // that plain rules can't express (a rule can only `get()` one known
      // document, not "this user's most recent job"). A direct client create
      // used to have no quota at all, so a script could mass-post spam jobs
      // (audit S10).
      allow create: if false;

      // Scoped update rules — prevents any auth user from vandalising any job:
      //  • employer: full update rights on their own job
      //  • operator: may only add/remove THEMSELVES in the applicants array —
      //    previously `hasOnly(['applicants'])` let any authenticated user
      //    overwrite the whole array (e.g. wipe out a competing applicant),
      //    as long as they didn't touch any other field (audit S5).
      //  • hired operator: may only toggle isReviewedByOperator (review submitted/deleted)
      allow update: if request.auth != null && (
        resource.data.employerId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicants']) &&
          request.resource.data.applicants.toSet().difference([request.auth.uid].toSet())
            == resource.data.applicants.toSet().difference([request.auth.uid].toSet())
        ) ||
        (resource.data.hiredOperatorId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['isReviewedByOperator']))
      );

      // Only the employer who posted the job may delete it
      allow delete: if request.auth != null &&
                       resource.data.employerId == request.auth.uid;
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public read: reviews visible on profiles
      allow read: if true;

      // A review can only be created under the author's own reviewerId
      allow create: if request.auth != null &&
                       request.resource.data.reviewerId == request.auth.uid;

      // Only the reviewer may edit or delete their own review
      allow update: if request.auth != null &&
                       resource.data.reviewerId == request.auth.uid;
      allow delete: if request.auth != null &&
                       resource.data.reviewerId == request.auth.uid;
    }

    // ── Job History ────────────────────────────────────────────────────────
    match /jobHistory/{historyId} {
      // Public read: job history entries are shown on public profiles.
      allow read: if true;

      // Only the referenced job's employer may create/update/delete history
      // entries for it — the hire/complete/cancel workflow is always driven
      // by the employer client-side, but nothing previously stopped any
      // authenticated user from writing fabricated "completed job" history
      // for a job they have no part in (audit S2).
      allow create: if request.auth != null &&
                       'jobId' in request.resource.data &&
                       get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.employerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
                       'jobId' in resource.data &&
                       get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid;
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Only the recipient may read their own notifications
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;

      // A notification may be sent to yourself freely (welcome/security
      // seeding), or to another user ONLY if both sender and recipient are
      // participants of the same job (`jobId`) — this bounds the previous
      // "any auth user can notify/spam/phish any other user" hole (audit S2)
      // to "job participants can notify each other", matching every real
      // notification flow (apply/hire/complete/review).
      allow create: if request.auth != null &&
                       request.resource.data.userId is string &&
                       (
                         request.resource.data.userId == request.auth.uid ||
                         (
                           'jobId' in request.resource.data &&
                           request.resource.data.jobId is string &&
                           isJobParticipant(request.resource.data.jobId, request.auth.uid) &&
                           isJobParticipant(request.resource.data.jobId, request.resource.data.userId)
                         )
                       );

      // Only the recipient may mark-read/delete their own notifications
      allow update, delete: if request.auth != null &&
                                resource.data.userId == request.auth.uid;
    }

    // ── Account Deletion Requests ────────────────────────────────────────────
    match /deletionRequests/{requestId} {
      // Write-only from the client: a user may file a request for their own
      // account, but can't read/edit/withdraw it themselves once submitted —
      // an admin reviews and actions these outside the app (see AGENTS.md /
      // audit S3, which found the Settings "delete account" button previously
      // persisted nothing at all).
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ── Rate Limits ───────────────────────────────────────────────────────
    // Counters for the pre-auth Cloud Functions' brute-force/enumeration
    // guard (functions/src/rateLimit.ts, audit S4). Admin SDK only — clients
    // never read or write this collection directly.
    match /rateLimits/{key} {
      allow read, write: if false;
    }
  }
}
