rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Public read: profiles visible on job cards, profile pages, SEO
      allow read: if true;

      // Only authenticated users may create their OWN document (UID must match)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Updates:
      //  • owner may update anything on their own document
      //  • any authenticated user may update only rating/ratingCount (review system)
      //  • password-reset flow: code verifies security answers, Firestore allows password-only write
      allow update: if (request.auth != null && request.auth.uid == userId) ||
                       (request.auth != null &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['rating', 'ratingCount'])) ||
                       (request.auth != null &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['password']));

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Jobs ───────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      // Public read: job board visible to guests
      allow read: if true;

      // Only authenticated users may post jobs
      allow create: if request.auth != null;

      // Any authenticated user may update a job (operators apply, employers hire/complete)
      allow update: if request.auth != null;

      // Only the employer who posted the job may delete it
      allow delete: if request.auth != null &&
                       resource.data.employerId == request.auth.uid;
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public read: reviews visible on profiles
      allow read: if true;

      allow create: if request.auth != null;

      // Only the reviewer may edit or delete their own review
      allow update: if request.auth != null &&
                       resource.data.reviewerId == request.auth.uid;
      allow delete: if request.auth != null &&
                       resource.data.reviewerId == request.auth.uid;
    }

    // ── Job History ────────────────────────────────────────────────────────
    match /jobHistory/{historyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Only the recipient may read their own notifications
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;
      allow write: if request.auth != null;
    }
  }
}
