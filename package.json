{
  "name": "antigravity-driver-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/generate-sitemap.mjs",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy:firebase": "next build && node scripts/generate-sitemap.mjs && npx --package firebase-tools firebase deploy",
    "postinstall": "node -e \"const{rmSync,existsSync}=require('fs');['@next/swc-linux-x64-gnu','@next/swc-linux-x64-musl','@next/swc-linux-arm64-gnu','@next/swc-linux-arm64-musl','@next/swc-darwin-arm64','@next/swc-darwin-x64','@next/swc-win32-arm64-msvc'].forEach(p=>{const d='node_modules/'+p;if(existsSync(d)){rmSync(d,{recursive:true,force:true});console.log('Removed unused SWC binary: '+p)}})\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
