rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Job images: authenticated users may upload; anyone may read
    match /jobs/{jobId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile images: only the owning user may upload; anyone may read
    match /profiles/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024   // 2 MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
