# GEMINI_API_KEY: Gemini calls run server-side only (functions/src/optimizeBio.ts).
# Set this as a Cloud Functions secret, NOT a client env var:
#   firebase functions:secrets:set GEMINI_API_KEY

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID: optional. Enables funnel tracking
# (src/lib/analytics.ts — search, view_job, contact_click, share_job,
# apply_submit, post_started/completed, sign_up_started/completed). Get this
# by linking Google Analytics to the Firebase project in Firebase Console →
# Project Settings → General → your web app. Leave unset to no-op tracking.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY: optional. Enables Firebase App Check
# (src/lib/firebase.ts), which proves requests to Firestore/Storage/Functions
# come from the real web app rather than a script (audit S4/S10). Get a site
# key by registering jolooch.net at google.com/recaptcha (reCAPTCHA v3) —
# there's no API for that specific step, it's a one-time manual registration.
# Leave unset to no-op — shipping this client SDK is safe on its own; actual
# enforcement is a separate, staged Firebase Console setting per service
# (Monitor mode first, watch traffic for a few days, then Enforce).
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=""
